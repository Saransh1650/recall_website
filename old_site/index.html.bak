<!-- ══ PROBLEM ══ -->
<div class="problem">
  <div class="problem-inner">
    <h2>Your mind was elsewhere.<br>The words are gone.</h2>
    <p>We've all been there — nodding through an important conversation, caught in our own thoughts, only to leave with a sinking feeling that we missed something crucial. RECALL was built for those moments.</p>
    <div class="ptags">
      <span class="ptag">😰 Anxiety &amp; overwhelm</span>
      <span class="ptag">🧠 ADHD &amp; focus challenges</span>
      <span class="ptag">👨‍⚕️ Doctor appointments</span>
      <span class="ptag">🎓 Academic mentoring</span>
      <span class="ptag">❤️ Family conversations</span>
      <span class="ptag">💼 Networking calls</span>
      <span class="ptag">🛋️ Therapy sessions</span>
    </div>
  </div>
</div>

<!-- ══ FEATURES ══ -->
<section id="features" class="section">
  <div class="section-center">
    <div class="label">✦ Features</div>
    <h2 class="section-h">Everything your memory<br>wishes it had</h2>
    <p class="section-sub">Built around your life, not your meetings.</p>
  </div>
  <div class="feat-grid">

    <!-- Recording -->
    <div class="feat-card fc-orange">
      <div class="feat-icon">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect x="9" y="3" width="10" height="16" rx="5" fill="#F06A2E"/>
          <path d="M5 14a9 9 0 0018 0" stroke="#F06A2E" stroke-width="2" stroke-linecap="round"/>
          <line x1="14" y1="23" x2="14" y2="26" stroke="#F06A2E" stroke-width="2" stroke-linecap="round"/>
          <line x1="10" y1="26" x2="18" y2="26" stroke="#F06A2E" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <h3 class="feat-title">One-tap recording</h3>
      <p class="feat-desc">Hit record, pocket your phone. RECALL captures everything in the background — even when your screen is locked. Noise suppression, silence detection, and a live timer in your notification bar.</p>
    </div>

    <!-- AI Journal -->
    <div class="feat-card fc-purple">
      <div class="feat-icon">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect x="4" y="3" width="20" height="25" rx="4" stroke="#7C5CFC" stroke-width="2"/>
          <line x1="9" y1="11" x2="19" y2="11" stroke="#7C5CFC" stroke-width="1.75" stroke-linecap="round"/>
          <line x1="9" y1="16" x2="19" y2="16" stroke="#7C5CFC" stroke-width="1.75" stroke-linecap="round"/>
          <line x1="9" y1="21" x2="14" y2="21" stroke="#7C5CFC" stroke-width="1.75" stroke-linecap="round"/>
          <circle cx="22" cy="5" r="5" fill="#7C5CFC"/>
          <path d="M20 5 L22 7 L25 3" stroke="white" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="feat-title">Beautiful AI journal entries</h3>
      <p class="feat-desc">Not just a transcript — RECALL writes a proper journal entry. Key points, decisions made, action items, quotes worth keeping, and even the emotional tone of the conversation.</p>
    </div>

    <!-- People -->
    <div class="feat-card fc-yellow">
      <div class="feat-icon">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <circle cx="10" cy="10" r="5" fill="#F5C842"/>
          <circle cx="20" cy="10" r="5" fill="#FFD580"/>
          <path d="M2 26c0-4.4 3.6-8 8-8" stroke="#F5C842" stroke-width="2" stroke-linecap="round"/>
          <path d="M20 18c4.4 0 8 3.6 8 8" stroke="#FFD580" stroke-width="2" stroke-linecap="round"/>
          <path d="M10 18c0 0 1-1 5-1s5 1 5 1" stroke="#F5C842" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <h3 class="feat-title">Know your people</h3>
      <p class="feat-desc">RECALL learns each voice. Name a speaker once and they're recognized in every future recording automatically. Navigate your entire journal by person, not just by date.</p>
    </div>

    <!-- Search -->
    <div class="feat-card fc-green">
      <div class="feat-icon">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <circle cx="12" cy="12" r="8" stroke="#16A34A" stroke-width="2"/>
          <line x1="18.5" y1="18.5" x2="25" y2="25" stroke="#16A34A" stroke-width="2" stroke-linecap="round"/>
          <path d="M9 12h6M12 9v6" stroke="#16A34A" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <h3 class="feat-title">Search your entire memory</h3>
      <p class="feat-desc">Ask anything in plain language. "What did Dr. Kumar say about my dosage?" "What advice did my mentor give?" RECALL finds the exact moment, highlighted in context.</p>
    </div>

  </div>
</section>

<!-- ══ HOW IT WORKS ══ -->
<section id="how-it-works" class="section-full" style="background:white; padding:6rem 1.5rem;">
  <div style="max-width:1200px; margin:0 auto;">
    <div class="section-center">
      <div class="label">✦ How it works</div>
      <h2 class="section-h">Simple as 1, 2, done.</h2>
      <p class="section-sub">No setup, no complicated workflows. Three steps from conversation to journal.</p>
    </div>
    <div class="steps">

      <div class="step">
        <div class="step-num">1</div>
        <div class="step-art">
          <svg viewBox="0 0 110 110" fill="none">
            <circle cx="55" cy="55" r="50" fill="#FFF3EB"/>
            <!-- Phone -->
            <rect x="30" y="18" width="50" height="82" rx="14" fill="#1C1917"/>
            <rect x="36" y="28" width="38" height="64" rx="8" fill="#2A2018"/>
            <!-- Record button -->
            <circle cx="55" cy="72" r="12" fill="rgba(240,106,46,0.2)"/>
            <circle cx="55" cy="72" r="8" fill="#F06A2E"/>
            <circle cx="55" cy="72" r="3.5" fill="white"/>
            <!-- Waveform -->
            <rect x="40" y="48" width="4" height="12" rx="2" fill="rgba(255,255,255,0.2)"/>
            <rect x="47" y="43" width="4" height="22" rx="2" fill="rgba(255,255,255,0.3)"/>
            <rect x="59" y="43" width="4" height="22" rx="2" fill="rgba(255,255,255,0.3)"/>
            <rect x="66" y="48" width="4" height="12" rx="2" fill="rgba(255,255,255,0.2)"/>
            <!-- Tap finger -->
            <circle cx="80" cy="88" r="10" fill="#FFD166" opacity="0.9"/>
            <text x="80" y="93" text-anchor="middle" font-size="12">👆</text>
          </svg>
        </div>
        <h3 class="step-title">Tap once to start</h3>
        <p class="step-desc">One tap is all it takes. RECALL records quietly in the background while you stay present in the conversation.</p>
      </div>

      <div class="step">
        <div class="step-num">2</div>
        <div class="step-art">
          <svg viewBox="0 0 110 110" fill="none">
            <circle cx="55" cy="55" r="50" fill="#F0EEFF"/>
            <!-- Waveform in -->
            <rect x="12" y="48" width="5" height="14" rx="2.5" fill="#7C5CFC" opacity="0.4"/>
            <rect x="20" y="40" width="5" height="30" rx="2.5" fill="#7C5CFC" opacity="0.55"/>
            <rect x="28" y="44" width="5" height="22" rx="2.5" fill="#7C5CFC" opacity="0.7"/>
            <!-- Arrow -->
            <path d="M38 55 L50 55" stroke="#C4B5FD" stroke-width="2" stroke-linecap="round"/>
            <path d="M46 51 L50 55 L46 59" stroke="#C4B5FD" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <!-- Journal -->
            <rect x="55" y="28" width="44" height="54" rx="8" fill="#FFF3EB" stroke="#FFD0B0" stroke-width="1.5"/>
            <rect x="63" y="40" width="28" height="5" rx="2.5" fill="#FFD0B0"/>
            <rect x="63" y="51" width="22" height="5" rx="2.5" fill="#FFD0B0"/>
            <rect x="63" y="62" width="26" height="5" rx="2.5" fill="#FFD0B0"/>
            <!-- Sparkles -->
            <path d="M88 20 L89.5 25 L94 27 L89.5 29 L88 34 L86.5 29 L82 27 L86.5 25 Z" fill="#F5C842"/>
            <path d="M18 26 L19.2 29.5 L23 31 L19.2 32.5 L18 36 L16.8 32.5 L13 31 L16.8 29.5 Z" fill="#7C5CFC" opacity="0.7"/>
          </svg>
        </div>
        <h3 class="step-title">AI does the magic</h3>
        <p class="step-desc">In under 60 seconds, RECALL transcribes, identifies each speaker, and writes a structured journal entry — completely automatically.</p>
      </div>

      <div class="step">
        <div class="step-num">3</div>
        <div class="step-art">
          <svg viewBox="0 0 110 110" fill="none">
            <circle cx="55" cy="55" r="50" fill="#ECFDF5"/>
            <!-- Open book -->
            <rect x="14" y="28" width="38" height="54" rx="6" fill="#FFD166"/>
            <rect x="58" y="28" width="38" height="54" rx="6" fill="#FFF3EB"/>
            <rect x="48" y="28" width="14" height="54" rx="4" fill="#F5C842"/>
            <!-- Left page lines -->
            <rect x="21" y="42" width="24" height="4.5" rx="2.25" fill="white" opacity="0.65"/>
            <rect x="21" y="53" width="18" height="4.5" rx="2.25" fill="white" opacity="0.65"/>
            <rect x="21" y="64" width="22" height="4.5" rx="2.25" fill="white" opacity="0.65"/>
            <!-- Right page lines -->
            <rect x="65" y="42" width="24" height="4.5" rx="2.25" fill="#FFD0B0"/>
            <rect x="65" y="53" width="18" height="4.5" rx="2.25" fill="#FFD0B0"/>
            <rect x="65" y="64" width="22" height="4.5" rx="2.25" fill="#FFD0B0"/>
            <!-- Heart -->
            <path d="M35 32 C35 30 37 28 39 30 C41 28 43 30 43 32 C43 36 39 39 39 39 C39 39 35 36 35 32Z" fill="#F06A2E" opacity="0.75"/>
            <!-- Check mark -->
            <circle cx="84" cy="84" r="12" fill="#16A34A"/>
            <path d="M79 84 L82.5 87.5 L89 80" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="step-title">Revisit &amp; reflect</h3>
        <p class="step-desc">Your journal is waiting. Read, edit, attach photos, search by person or topic, and relive any conversation exactly as it happened.</p>
      </div>

    </div>
  </div>
</section>

