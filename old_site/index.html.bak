<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RECALL — Be Present. We'll Remember.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #FDFAF4;
      --white: #FFFFFF;
      --border: #E8E2D9;
      --text: #1C1917;
      --mid: #78716C;
      --light: #A8A29E;
      --orange: #F06A2E;
      --orange-dark: #C9521A;
      --orange-bg: #FFF3EB;
      --orange-bg2: #FFE0C8;
      --purple: #7C5CFC;
      --purple-bg: #F0EEFF;
      --yellow: #F5C842;
      --yellow-bg: #FFFAEB;
      --green: #16A34A;
      --green-bg: #ECFDF5;
      --r-sm: 12px; --r-md: 20px; --r-lg: 28px; --r-xl: 48px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    h1,h2,h3,h4 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    /* ── NAV ── */
    .nav {
      position: fixed; top: 1rem; left: 50%; transform: translateX(-50%);
      z-index: 1000;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.875rem 1.5rem;
      background: rgba(253,250,244,0.88);
      backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(0,0,0,0.07);
      border-radius: 100px;
      width: calc(100% - 3rem); max-width: 1080px;
      transition: padding 0.3s;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 0.5rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800; font-size: 1.15rem; color: var(--text);
      text-decoration: none; letter-spacing: -0.02em;
    }
    .logo-mark {
      width: 30px; height: 30px; border-radius: 8px;
      background: var(--orange);
      display: flex; align-items: center; justify-content: center;
    }
    .nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
    .nav-links a {
      color: var(--mid); text-decoration: none; font-size: 0.875rem;
      font-weight: 500; transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.55rem 1.2rem; border-radius: 100px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700; font-size: 0.85rem;
      text-decoration: none; cursor: pointer; border: none;
      transition: all 0.2s ease;
    }
    .btn-ghost { background: transparent; color: var(--mid); }
    .btn-ghost:hover { background: rgba(0,0,0,0.05); color: var(--text); }
    .btn-primary { background: var(--orange); color: white; box-shadow: 0 2px 10px rgba(240,106,46,0.25); }
    .btn-primary:hover { background: var(--orange-dark); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(240,106,46,0.35); }

    /* ── HERO ── */
    .hero {
      padding: 8rem 1.5rem 4rem;
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 3rem; align-items: center; min-height: 95vh;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.6rem;
      background: var(--orange-bg); color: var(--orange);
      padding: 0.35rem 1rem 0.35rem 0.5rem;
      border-radius: 100px; font-size: 0.8rem; font-weight: 600;
      margin-bottom: 1.75rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .pulse-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--orange); animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%,100% { transform: scale(1); opacity:1; }
      50% { transform: scale(1.4); opacity:0.6; }
    }
    .hero-title {
      font-size: 4.5rem; font-weight: 800; color: var(--text);
      margin-bottom: 1.5rem; letter-spacing: -0.03em;
    }
    .underline-yellow {
      text-decoration: underline;
      text-decoration-color: var(--yellow);
      text-decoration-thickness: 5px;
      text-underline-offset: 5px;
    }
    .hero-sub {
      font-size: 1.1rem; color: var(--mid);
      margin-bottom: 2.5rem; max-width: 460px; line-height: 1.75;
    }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
    .store-btn {
      display: flex; align-items: center; gap: 0.75rem;
      background: var(--text); color: white;
      padding: 0.75rem 1.5rem; border-radius: 14px;
      text-decoration: none; transition: all 0.2s;
    }
    .store-btn:hover { background: #2C2920; transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,0.2); }
    .sbt { display: flex; flex-direction: column; }
    .sbt-sub { font-size: 0.625rem; opacity: 0.6; letter-spacing: 0.04em; text-transform: uppercase; }
    .sbt-name { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.95rem; }
    .hero-trust { display: flex; align-items: center; gap: 0.875rem; }
    .trust-avatars { display: flex; }
    .ta {
      width: 30px; height: 30px; border-radius: 50%;
      border: 2px solid var(--bg); margin-left: -8px;
    }
    .ta:first-child { margin-left: 0; }
    .hero-trust p { font-size: 0.825rem; color: var(--light); }
    .hero-trust p strong { color: var(--mid); font-weight: 600; }

    /* ── HERO ILLUSTRATION ── */
    .hero-visual { position: relative; display: flex; align-items: center; justify-content: center; }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-9px)} }
    @keyframes float2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
    .f1 { animation: float 4s ease-in-out infinite; }
    .f2 { animation: float2 5s ease-in-out infinite 0.7s; }
    .f3 { animation: float 4.5s ease-in-out infinite 1.2s; }

    /* ── MARQUEE ── */
    .marquee-wrap {
      padding: 1.5rem 0; background: white;
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      overflow: hidden;
    }
    .marquee-track {
      display: flex; gap: 3rem; white-space: nowrap;
      animation: marquee 24s linear infinite;
    }
    @keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
    .mi {
      display: inline-flex; align-items: center; gap: 0.6rem;
      color: var(--mid); font-size: 0.875rem; font-weight: 500; flex-shrink: 0;
    }
    .mdot { width: 5px; height: 5px; border-radius: 50%; background: var(--orange); }

    /* ── PROBLEM BAND ── */
    .problem {
      background: var(--text); color: white;
      padding: 5.5rem 1.5rem; text-align: center;
    }
    .problem-inner { max-width: 780px; margin: 0 auto; }
    .problem h2 { font-size: 2.75rem; font-weight: 800; color: white; margin-bottom: 1.25rem; letter-spacing: -0.025em; }
    .problem p { font-size: 1.1rem; color: rgba(255,255,255,0.6); line-height: 1.8; margin-bottom: 2.5rem; }
    .ptags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; }
    .ptag {
      background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.8);
      padding: 0.45rem 1.1rem; border-radius: 100px;
      font-size: 0.875rem; border: 1px solid rgba(255,255,255,0.12);
    }

    /* ── SECTIONS ── */
    .section { padding: 6rem 1.5rem; max-width: 1200px; margin: 0 auto; }
    .section-full { padding: 6rem 1.5rem; }
    .section-center { text-align: center; margin-bottom: 4rem; }
    .label {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700; font-size: 0.7rem; text-transform: uppercase;
      letter-spacing: 0.14em; color: var(--light); margin-bottom: 1rem;
    }
    .section-h { font-size: 2.75rem; font-weight: 800; margin-bottom: 1rem; letter-spacing: -0.025em; }
    .section-sub { font-size: 1.05rem; color: var(--mid); max-width: 540px; line-height: 1.75; }
    .section-center .section-sub { margin: 0 auto; }

    /* ── FEATURES GRID ── */
    .feat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .feat-card {
      border-radius: var(--r-lg); padding: 2.5rem;
      border: 1.5px solid transparent;
      transition: transform 0.3s, box-shadow 0.3s;
      position: relative; overflow: hidden;
    }
    .feat-card:hover { transform: translateY(-5px); box-shadow: 0 24px 60px rgba(0,0,0,0.07); }
    .fc-orange { background: var(--orange-bg); }
    .fc-purple { background: var(--purple-bg); }
    .fc-yellow { background: var(--yellow-bg); }
    .fc-green  { background: var(--green-bg); }
    .feat-icon {
      width: 52px; height: 52px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.5rem; background: rgba(255,255,255,0.7);
    }
    .feat-title { font-size: 1.3rem; font-weight: 800; margin-bottom: 0.75rem; }
    .feat-desc { font-size: 0.925rem; color: var(--mid); line-height: 1.72; }

    /* ── STEPS ── */
    .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; position: relative; }
    .steps::before {
      content: ''; position: absolute;
      top: 56px; left: calc(16.7% + 1rem); right: calc(16.7% + 1rem);
      height: 2px; background: linear-gradient(90deg, var(--orange), var(--purple));
      opacity: 0.15;
    }
    .step { text-align: center; padding: 2rem 1.5rem; }
    .step-num {
      width: 48px; height: 48px; border-radius: 50%;
      background: var(--orange-bg); color: var(--orange);
      font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.2rem;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem; position: relative; z-index: 1;
    }
    .step-art { margin: 0 auto 1.5rem; width: 110px; height: 110px; }
    .step-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; }
    .step-desc { font-size: 0.875rem; color: var(--mid); line-height: 1.7; }

    /* ── PERSONAS ── */
    .personas { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
    .persona {
      background: white; border-radius: var(--r-md);
      padding: 1.75rem; border: 1.5px solid var(--border);
      transition: all 0.3s;
    }
    .persona:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.08); border-color: var(--orange-bg2); }
    .persona-avatar { width: 56px; height: 56px; border-radius: 50%; margin-bottom: 1rem; }
    .persona-role { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--orange); margin-bottom: 0.2rem; }
    .persona-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; }
    .persona-quote { font-size: 0.85rem; color: var(--mid); line-height: 1.7; font-style: italic; }

    /* ── PRICING ── */
    .pricing { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; align-items: center; }
    .price-card { background: white; border-radius: var(--r-lg); padding: 2.25rem; border: 1.5px solid var(--border); }
    .price-card.featured { background: var(--text); color: white; border-color: var(--text); transform: scale(1.05); box-shadow: 0 24px 64px rgba(0,0,0,0.18); }
    .price-badge {
      display: inline-block; background: var(--yellow); color: var(--text);
      padding: 0.2rem 0.7rem; border-radius: 100px;
      font-size: 0.7rem; font-weight: 700; margin-bottom: 1.25rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .price-tier { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.4rem; }
    .price-card:not(.featured) .price-tier { color: var(--light); }
    .price-card.featured .price-tier { color: rgba(255,255,255,0.45); }
    .price-amount { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 2.75rem; letter-spacing: -0.03em; margin-bottom: 0.2rem; }
    .price-period { font-size: 0.825rem; margin-bottom: 1.5rem; }
    .price-card:not(.featured) .price-period { color: var(--light); }
    .price-card.featured .price-period { color: rgba(255,255,255,0.45); }
    .price-div { height: 1px; margin-bottom: 1.5rem; }
    .price-card:not(.featured) .price-div { background: var(--border); }
    .price-card.featured .price-div { background: rgba(255,255,255,0.1); }
    .price-features { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; }
    .pf { display: flex; align-items: flex-start; gap: 0.7rem; font-size: 0.875rem; }
    .pf-check {
      flex-shrink: 0; width: 18px; height: 18px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; margin-top: 2px;
    }
    .price-card:not(.featured) .pf-check { background: var(--green-bg); }
    .price-card.featured .pf-check { background: rgba(255,255,255,0.12); }
    .price-btn {
      width: 100%; text-align: center; padding: 0.8rem;
      border-radius: var(--r-sm);
      font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.875rem;
      cursor: pointer; border: none; text-decoration: none; display: block; transition: all 0.2s;
    }
    .price-card:not(.featured) .price-btn { background: var(--bg); color: var(--text); }
    .price-card:not(.featured) .price-btn:hover { background: var(--orange); color: white; }
    .price-card.featured .price-btn { background: var(--orange); color: white; }
    .price-card.featured .price-btn:hover { background: #FF7A40; }

    /* ── PRIVACY ── */
    .privacy-box {
      background: var(--purple-bg); border-radius: var(--r-xl);
      padding: 5rem 4rem;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4rem; align-items: center;
      max-width: 1200px; margin: 0 auto 6rem;
    }
    .priv-features { display: flex; flex-direction: column; gap: 1.5rem; }
    .priv-feat { display: flex; align-items: flex-start; gap: 1rem; }
    .priv-icon {
      width: 42px; height: 42px; border-radius: 12px;
      background: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .priv-feat h4 { font-size: 0.975rem; font-weight: 700; margin-bottom: 0.2rem; }
    .priv-feat p { font-size: 0.85rem; color: var(--mid); line-height: 1.6; }

    /* ── CTA ── */
    .cta-section {
      text-align: center; padding: 6rem 1.5rem;
      background: linear-gradient(140deg, var(--orange-bg) 0%, var(--purple-bg) 100%);
    }
    .cta-inner { max-width: 680px; margin: 0 auto; }
    .cta-title { font-size: 3rem; font-weight: 800; margin-bottom: 1.25rem; letter-spacing: -0.025em; }
    .cta-sub { font-size: 1.05rem; color: var(--mid); margin-bottom: 2.5rem; line-height: 1.75; }
    .cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* ── FOOTER ── */
    .footer { background: var(--text); color: white; padding: 4rem 1.5rem 2rem; }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-top {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 3rem; padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 2rem;
    }
    .footer-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.45); margin-top: 1rem; line-height: 1.7; max-width: 260px; }
    .footer-col-title { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(255,255,255,0.35); margin-bottom: 1rem; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    .footer-links a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
    .footer-links a:hover { color: white; }
    .footer-bottom { display: flex; align-items: center; justify-content: space-between; font-size: 0.8rem; color: rgba(255,255,255,0.3); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .nav-links { display: none; }
      .hero { grid-template-columns: 1fr; min-height: auto; padding-top: 6rem; }
      .hero-visual { display: none; }
      .hero-title { font-size: 3rem; }
      .feat-grid { grid-template-columns: 1fr; }
      .steps { grid-template-columns: 1fr; }
      .steps::before { display: none; }
      .personas { grid-template-columns: 1fr 1fr; }
      .pricing { grid-template-columns: 1fr; }
      .price-card.featured { transform: none; }
      .privacy-box { grid-template-columns: 1fr; padding: 3rem 2rem; }
      .footer-top { grid-template-columns: 1fr 1fr; }
      .problem h2 { font-size: 2rem; }
    }
    @media (max-width: 500px) {
      .personas { grid-template-columns: 1fr; }
      .hero-title { font-size: 2.5rem; }
      .cta-title { font-size: 2.25rem; }
    }
  </style>
</head>
<body>

<!-- ══ NAV ══ -->
<nav class="nav" id="navbar">
  <a href="#" class="nav-logo">
    <div class="logo-mark">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="5" stroke="white" stroke-width="2"/>
        <circle cx="8" cy="8" r="2" fill="white"/>
      </svg>
    </div>
    RECALL
  </a>
  <ul class="nav-links">
    <li><a href="#features">Features</a></li>
    <li><a href="#how-it-works">How it works</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#privacy">Privacy</a></li>
  </ul>
  <div class="nav-actions">
    <a href="#" class="btn btn-ghost">Log in</a>
    <a href="#" class="btn btn-primary">Get the app →</a>
  </div>
</nav>

<!-- ══ HERO ══ -->
<section>
  <div class="hero">
    <div>
      <div class="hero-eyebrow"><span class="pulse-dot"></span> Now in Early Access</div>
      <h1 class="hero-title">Be present.<br>We'll <span class="underline-yellow">remember.</span></h1>
      <p class="hero-sub">RECALL listens to your conversations and turns them into beautiful journal entries — so you can stop worrying about forgetting and start actually being there.</p>
      <div class="hero-ctas">
        <a href="#" class="store-btn">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="white"><path d="M17.05 11.2c-.02-1.98 1.63-2.94 1.7-2.98-.93-1.36-2.37-1.54-2.88-1.56-1.22-.12-2.4.72-3.02.72-.63 0-1.58-.7-2.6-.68-1.33.02-2.57.78-3.25 1.97-1.4 2.42-.36 5.97.99 7.92.67.96 1.45 2.03 2.48 1.99 1-.04 1.38-.64 2.59-.64 1.2 0 1.55.64 2.6.62 1.08-.02 1.75-1.03 2.38-2 .76-1.14 1.07-2.25 1.09-2.31-.02-.01-2.1-.81-2.08-3.05zM15.15 5.56c.55-.67.93-1.6.82-2.53-.8.03-1.77.53-2.34 1.2-.51.59-.96 1.54-.84 2.44.88.07 1.79-.45 2.36-1.11z"/></svg>
          <div class="sbt"><span class="sbt-sub">Download on the</span><span class="sbt-name">App Store</span></div>
        </a>
        <a href="#" class="store-btn">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4.5 4L12.5 11L4.5 18V4Z" fill="#00E5FF"/><path d="M4.5 4L12.5 11L17 8.5L4.5 4Z" fill="#FFD740"/><path d="M12.5 11L17 13.5L4.5 18L12.5 11Z" fill="#FF6D00"/><path d="M17 8.5L12.5 11L17 13.5L17 8.5Z" fill="#FF4081"/></svg>
          <div class="sbt"><span class="sbt-sub">Get it on</span><span class="sbt-name">Google Play</span></div>
        </a>
      </div>
      <div class="hero-trust">
        <div class="trust-avatars">
          <div class="ta" style="background:#FFB3A3;"></div>
          <div class="ta" style="background:#A3D9FF;"></div>
          <div class="ta" style="background:#B3FFD1;"></div>
          <div class="ta" style="background:#FFD9A3;"></div>
          <div class="ta" style="background:#D9B3FF;"></div>
        </div>
        <p><strong>2,400+ people</strong> on the waitlist</p>
      </div>
    </div>

    <!-- HERO ILLUSTRATION -->
    <div class="hero-visual">
      <svg width="500" height="540" viewBox="0 0 500 540" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Soft background blobs -->
        <ellipse cx="250" cy="290" rx="190" ry="165" fill="#F0EEFF" opacity="0.55"/>
        <ellipse cx="310" cy="200" rx="90" ry="80" fill="#FFF3EB" opacity="0.6"/>

        <!-- Left speech bubble -->
        <g class="f1">
          <rect x="28" y="115" width="136" height="68" rx="16" fill="white" stroke="#E8E2D9" stroke-width="1.5"/>
          <rect x="46" y="136" width="100" height="9" rx="4.5" fill="#E8E2D9"/>
