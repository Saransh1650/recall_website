<!-- ══ PRIVACY ══ -->
<div class="section-full" id="privacy" style="padding:2rem 1.5rem 6rem;">
  <div class="privacy-box">
    <div>
      <div class="label">✦ Privacy</div>
      <h2 class="section-h" style="margin-bottom:1.25rem;">Your memories are<br>yours. Full stop.</h2>
      <p class="section-sub">We built RECALL with privacy as a first principle, not an afterthought. Every decision was made with your most sensitive conversations in mind.</p>
    </div>
    <div class="priv-features">
      <div class="priv-feat">
        <div class="priv-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 2L4 5.5v4c0 3.9 2.9 7.5 7 8.6 4.1-1.1 7-4.7 7-8.6v-4L11 2z" stroke="#7C5CFC" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 11l2 2.5 4-5" stroke="#7C5CFC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <h4>On-device private mode</h4>
          <p>Process everything locally using Whisper on your phone. Nothing leaves your device.</p>
        </div>
      </div>
      <div class="priv-feat">
        <div class="priv-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="4" y="10" width="14" height="10" rx="3" stroke="#7C5CFC" stroke-width="1.5"/><path d="M7 10V7a4 4 0 018 0v3" stroke="#7C5CFC" stroke-width="1.5" stroke-linecap="round"/><circle cx="11" cy="15" r="1.5" fill="#7C5CFC"/></svg>
        </div>
        <div>
          <h4>AES-256 encrypted storage</h4>
          <p>Your audio is encrypted at rest and in transit with TLS 1.3. Always.</p>
        </div>
      </div>
      <div class="priv-feat">
        <div class="priv-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 4v8" stroke="#7C5CFC" stroke-width="1.5" stroke-linecap="round"/><circle cx="11" cy="15" r="1.5" fill="#7C5CFC"/><circle cx="11" cy="11" r="8" stroke="#7C5CFC" stroke-width="1.5"/></svg>
        </div>
        <div>
          <h4>Consent-first design</h4>
          <p>No passive always-on recording. You actively start every session. Your consent, your rules.</p>
        </div>
      </div>
      <div class="priv-feat">
        <div class="priv-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="3" y="3" width="16" height="16" rx="4" stroke="#7C5CFC" stroke-width="1.5"/><path d="M7 11l3 3 5-5" stroke="#7C5CFC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <h4>GDPR &amp; IT Act compliant</h4>
          <p>Built from the ground up for global and Indian data privacy standards.</p>
        </div>
      </div>
    </div>
  </div>
</div>

